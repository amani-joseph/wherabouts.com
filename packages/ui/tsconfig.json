{
  "extends": "@wherabouts.com/config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@wherabouts.com/ui/*": ["./src/*"]
    },
    "strictNullChecks": true,
    "types": ["node", "geojson"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
