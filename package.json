{
  "name": "wherabouts.com",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @wherabouts.com/backend dev",
    "dev:setup": "turbo -F @wherabouts.com/backend dev:setup",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "deploy": "turbo -F @wherabouts.com/backend deploy && turbo -F web deploy",
    "deploy:web": "turbo -F web deploy",
    "deploy:convex": "turbo -F @wherabouts.com/backend deploy"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@wherabouts.com/env": "workspace:*",
    "dotenv": "catalog:",
    "tsx": "^4.21.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@wherabouts.com/config": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "^5",
    "ultracite": "7.4.4"
  },
  "packageManager": "pnpm@10.12.4"
}
